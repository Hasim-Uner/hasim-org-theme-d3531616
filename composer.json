{
    "name": "hasim-uner/hasimuener-journal",
    "description": "Hasimuener Journal — editorial GeneratePress child theme. Dev tooling for static analysis and CI.",
    "type": "wordpress-theme",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "php-stubs/wordpress-stubs": "^6.5"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "lint": "find . -name '*.php' -not -path './vendor/*' -not -path './_stitch/*' -not -path './_build-d3/*' -not -path './inc/contact-local.php' -print0 | xargs -0 -n1 php -l",
        "check:manifest": "php scripts/check-manifest.php",
        "check:seo-architecture": "php scripts/check-seo-architecture.php",
        "docs:generate": "php scripts/generate-wp-docs.php",
        "docs:check": "php scripts/generate-wp-docs.php && git diff --exit-code -- docs/HOOKS.md docs/REST_ROUTES.md",
        "analyse": "phpstan analyse --memory-limit=-1",
        "ci": [
            "@lint",
            "@check:manifest",
            "@check:seo-architecture",
            "@docs:check",
            "@analyse"
        ]
    }
}
